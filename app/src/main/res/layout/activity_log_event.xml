<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_log_event.xml
    Manual event logger — icon-based, minimal text required.

    Sections:
      1. Trigger type  — 6 large icon cards (tap to select one)
      2. Severity      — 5 emoji buttons (😌 → 😰)
      3. Location      — 4 chip options
      4. Notes         — optional free text
      5. Save button
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="←"
                android:textSize="20sp"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/bg_avatar_circle"
                android:backgroundTint="#10000000"
                android:contentDescription="Go back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log a Moment"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- ── SECTION 1: TRIGGER TYPE ──────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What was hard?"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <!-- 2x3 grid of trigger cards -->
        <GridLayout
            android:id="@+id/grid_triggers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:layout_marginBottom="28dp">

            <!-- NOISE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trigger_noise"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Loud sounds trigger"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔊" android:textSize="28sp" android:gravity="center"
                        android:importantForAccessibility="no"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Loud sounds" android:textSize="11sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- LIGHT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trigger_light"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Bright lights trigger"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡" android:textSize="28sp" android:gravity="center"
                        android:importantForAccessibility="no"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bright lights" android:textSize="11sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CROWD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trigger_crowd"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Crowded places trigger"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👥" android:textSize="28sp" android:gravity="center"
                        android:importantForAccessibility="no"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Crowded" android:textSize="11sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TEXTURE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trigger_texture"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Touch or texture trigger"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✋" android:textSize="28sp" android:gravity="center"
                        android:importantForAccessibility="no"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Touch" android:textSize="11sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SMELL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trigger_smell"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Strong smell trigger"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👃" android:textSize="28sp" android:gravity="center"
                        android:importantForAccessibility="no"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Strong smell" android:textSize="11sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SUDDEN CHANGE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trigger_change"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Sudden change trigger"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔄" android:textSize="28sp" android:gravity="center"
                        android:importantForAccessibility="no"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sudden change" android:textSize="11sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- ── SECTION 2: SEVERITY ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How bad did it feel?"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <!-- 5 emoji severity buttons in a row -->
        <LinearLayout
            android:id="@+id/ll_severity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView android:id="@+id/sev_1"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="1" android:gravity="center"
                android:text="😌" android:textSize="28sp"
                android:contentDescription="Severity 1, very mild"
                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView android:id="@+id/sev_2"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="1" android:gravity="center"
                android:text="😕" android:textSize="28sp"
                android:contentDescription="Severity 2, mild"
                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView android:id="@+id/sev_3"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="1" android:gravity="center"
                android:text="😣" android:textSize="28sp"
                android:contentDescription="Severity 3, moderate"
                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView android:id="@+id/sev_4"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="1" android:gravity="center"
                android:text="😫" android:textSize="28sp"
                android:contentDescription="Severity 4, strong"
                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView android:id="@+id/sev_5"
                android:layout_width="0dp" android:layout_height="60dp"
                android:layout_weight="1" android:gravity="center"
                android:text="😰" android:textSize="28sp"
                android:contentDescription="Severity 5, extreme"
                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>

        <!-- Live severity label -->
        <TextView
            android:id="@+id/tv_severity_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to rate"
            android:textSize="@dimen/text_caption"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- ── SECTION 3: LOCATION ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Where were you?"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="28dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_loc_home"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="🏠 Home"
                android:textSize="@dimen/text_caption"
                android:checked="true"
                android:contentDescription="Location: Home" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_loc_school"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="🏫 School"
                android:textSize="@dimen/text_caption"
                android:contentDescription="Location: School" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_loc_public"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="🏙 Public"
                android:textSize="@dimen/text_caption"
                android:contentDescription="Location: Public place" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_loc_other"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="📍 Other"
                android:textSize="@dimen/text_caption"
                android:contentDescription="Location: Other" />

        </com.google.android.material.chip.ChipGroup>

        <!-- ── SECTION 4: WHEN DID THIS HAPPEN? ───────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="When did it happen?"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_time_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🕐  Time"
                    android:textSize="15sp"
                    android:textColor="?android:attr/textColorPrimary" />
                <TextView
                    android:id="@+id/tv_selected_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Right now"
                    android:textSize="15sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ›"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── SECTION 5: NOTES (optional) ──────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Any notes? (optional)"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="What happened? How did you feel?">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:maxLines="5"
                android:textSize="@dimen/text_body"
                android:inputType="textMultiLine|textCapSentences"
                android:contentDescription="Optional notes about what happened" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── SAVE BUTTON ───────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_event"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height_standard"
            android:text="Save moment"
            android:textSize="16sp"
            app:cornerRadius="@dimen/btn_corner_radius"
            android:contentDescription="Save this sensory event" />

    </LinearLayout>
</ScrollView>
