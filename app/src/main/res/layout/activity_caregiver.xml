<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_caregiver.xml
    PIN-protected caregiver dashboard.

    Sections (visible after PIN unlock):
      1. This-week stats   — moment count, avg intensity, best calm tool
      2. Last-7-days chart — proportional day bars
      3. Recent moments    — last 5 events (built programmatically)
      4. Caregiver notes   — free-text notes from sensory profile
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- ── HEADER ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="←"
                android:textSize="22sp"
                android:textColor="?attr/colorPrimary"
                android:contentDescription="Go back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Caregiver View"
                android:textSize="@dimen/text_headline"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginStart="8dp" />

            <!-- Lock button (shown after PIN unlock) -->
            <TextView
                android:id="@+id/btn_lock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 Lock"
                android:textSize="13sp"
                android:textColor="?attr/colorPrimary"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Lock caregiver dashboard"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── DASHBOARD (shown after PIN) ───────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 1. This-week stats card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THIS WEEK"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:letterSpacing="0.10"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Moments count -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_week_events"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="?android:attr/textColorPrimary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="moments"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="?attr/colorOnSurface"
                            android:alpha="0.15"
                            android:layout_gravity="center_vertical" />

                        <!-- Average intensity -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_avg_severity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="?android:attr/textColorPrimary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="avg intensity"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="?attr/colorOnSurface"
                            android:alpha="0.15"
                            android:layout_gravity="center_vertical" />

                        <!-- Best calm tool -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_best_tool_emoji"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌬️"
                                android:textSize="28sp"
                                android:gravity="center"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/tv_best_tool"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Breathing"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:gravity="center"
                                android:maxLines="2" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Last-7-days bar chart -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0DDFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last 7 days"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="16dp" />

                    <!-- Day bars — built programmatically in CaregiverActivity -->
                    <LinearLayout
                        android:id="@+id/ll_heatmap"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:baselineAligned="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Recent moments -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0DDFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent moments"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="8dp" />

                    <!-- Event rows added programmatically -->
                    <LinearLayout
                        android:id="@+id/ll_recent_events"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Caregiver notes -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F0C060">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Notes for carers"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_caregiver_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No notes added yet."
                        android:textSize="@dimen/text_body"
                        android:textColor="?android:attr/textColorSecondary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
