<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_onboarding_theme.xml  — FIXED
    Duplicate IDs removed. Each card now has unique IDs.
    viewBinding requires all IDs in a layout to be unique.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="@dimen/screen_padding_horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_theme_title"
            android:textSize="@dimen/text_headline"
            android:textColor="?attr/android:textColorPrimary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You can change this anytime in settings."
            android:textSize="@dimen/text_caption"
            android:textColor="?attr/android:textColorSecondary"
            android:layout_marginBottom="24dp" />

        <!-- ── WARM & DIM ─────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_theme_warm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:focusable="true"
            android:clickable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <View
                        android:id="@+id/warm_preview_strip"
                        android:layout_width="16dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="#FDF3E3" />
                    <View
                        android:id="@+id/warm_accent_bar"
                        android:layout_width="16dp"
                        android:layout_height="6dp"
                        android:background="#BA7517" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tv_warm_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_warm"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="?attr/android:textColorPrimary"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_warm_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soft amber tones — great for bright light sensitivity"
                        android:textSize="@dimen/text_caption"
                        android:textColor="?attr/android:textColorSecondary"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_warm_check"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="✓"
                    android:textSize="22sp"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="invisible" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── COOL & MUTED ───────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_theme_cool"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:focusable="true"
            android:clickable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <View
                        android:id="@+id/cool_preview_strip"
                        android:layout_width="16dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="#EEF4FB" />
                    <View
                        android:id="@+id/cool_accent_bar"
                        android:layout_width="16dp"
                        android:layout_height="6dp"
                        android:background="#185FA5" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tv_cool_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_cool"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="?attr/android:textColorPrimary"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_cool_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calm blue-green — easy on tired eyes"
                        android:textSize="@dimen/text_caption"
                        android:textColor="?attr/android:textColorSecondary"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_cool_check"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="✓"
                    android:textSize="22sp"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="invisible" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── HIGH CONTRAST ──────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_theme_dark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:focusable="true"
            android:clickable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <View
                        android:id="@+id/dark_preview_strip"
                        android:layout_width="16dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="#0F0F1A" />
                    <View
                        android:id="@+id/dark_accent_bar"
                        android:layout_width="16dp"
                        android:layout_height="6dp"
                        android:background="#A78BFA" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tv_dark_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_dark"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="?attr/android:textColorPrimary"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_dark_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark background — strong contrast, no glare"
                        android:textSize="@dimen/text_caption"
                        android:textColor="?attr/android:textColorSecondary"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_dark_check"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="✓"
                    android:textSize="22sp"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="invisible" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── STANDARD ───────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_theme_standard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:focusable="true"
            android:clickable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <View
                        android:id="@+id/standard_preview_strip"
                        android:layout_width="16dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="#F8F7FF" />
                    <View
                        android:id="@+id/standard_accent_bar"
                        android:layout_width="16dp"
                        android:layout_height="6dp"
                        android:background="#534AB7" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tv_standard_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_standard"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="?attr/android:textColorPrimary"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_standard_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clean and bright — classic look"
                        android:textSize="@dimen/text_caption"
                        android:textColor="?attr/android:textColorSecondary"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_standard_check"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="✓"
                    android:textSize="22sp"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="visible" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
