<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none"
    android:background="?attr/android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Shield in a soft circle -->
        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="12dp"
            android:layout_gravity="center_horizontal">
            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/bg_soft_circle_purple"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🛡️"
                android:textSize="52sp"
                android:gravity="center"
                android:contentDescription="SenseShield logo"/>
        </FrameLayout>

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SenseShield"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:layout_marginBottom="8dp"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your calm, always close."
            android:textSize="16sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Three promise rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorSurface"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🔔"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:importantForAccessibility="no"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Gentle alerts before things feel overwhelming"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🎵"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:importantForAccessibility="no"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Calming sounds, breathing, visuals — one tap away"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- FIX: lock row uses layout_weight="1" so text never clips on narrow screens -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:importantForAccessibility="no"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Your data stays private on this device"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap Next to personalise your experience →"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>