<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="8dp">

        <!-- Back button — large, pill-shaped, clearly tappable -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_step"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="← Back"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:contentDescription="Go to previous step"
            android:visibility="invisible"
            app:cornerRadius="22dp"/>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/onboarding_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:max="100"
            android:progress="17"
            android:progressTint="?attr/colorPrimary"
            android:progressBackgroundTint="#E0E0E0"/>

        <!-- Step counter -->
        <TextView
            android:id="@+id/tv_step_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:text="1 / 6"/>

    </LinearLayout>

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/onboarding_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp">

        <View android:id="@+id/dot_0" android:layout_width="14dp"
            android:layout_height="14dp" android:layout_margin="5dp"
            android:background="@drawable/bg_dot_active"/>
        <View android:id="@+id/dot_1" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_margin="5dp"
            android:background="@drawable/bg_dot_inactive"/>
        <View android:id="@+id/dot_2" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_margin="5dp"
            android:background="@drawable/bg_dot_inactive"/>
        <View android:id="@+id/dot_3" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_margin="5dp"
            android:background="@drawable/bg_dot_inactive"/>
        <View android:id="@+id/dot_4" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_margin="5dp"
            android:background="@drawable/bg_dot_inactive"/>
        <View android:id="@+id/dot_5" android:layout_width="8dp"
            android:layout_height="8dp" android:layout_margin="5dp"
            android:background="@drawable/bg_dot_inactive"/>

    </LinearLayout>

    <!-- Next button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:text="Let's begin →"
        android:textSize="17sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:contentDescription="Continue to next step"
        app:cornerRadius="30dp"/>

</LinearLayout>
