<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimum touch target — 48dp is the Android Material accessibility requirement -->
    <dimen name="touch_target_min">48dp</dimen>

    <!-- Spacing -->
    <dimen name="spacing_xs">4dp</dimen>
    <dimen name="spacing_sm">8dp</dimen>
    <dimen name="spacing_md">16dp</dimen>
    <dimen name="spacing_lg">24dp</dimen>
    <dimen name="spacing_xl">32dp</dimen>
    <dimen name="spacing_xxl">48dp</dimen>

    <!-- Screen padding -->
    <dimen name="screen_padding_horizontal">24dp</dimen>
    <dimen name="screen_padding_vertical">16dp</dimen>

    <!-- Cards -->
    <dimen name="card_corner_radius">12dp</dimen>
    <dimen name="card_elevation">2dp</dimen>

    <!-- Buttons -->
    <dimen name="btn_height_large">72dp</dimen>   <!-- Emergency calm button -->
    <dimen name="btn_height_standard">56dp</dimen>
    <dimen name="btn_corner_radius">28dp</dimen>

    <!-- Avatar -->
    <dimen name="avatar_size_large">80dp</dimen>
    <dimen name="avatar_size_small">40dp</dimen>
    <dimen name="avatar_picker_size">48dp</dimen>  <!-- Also satisfies touch target minimum -->

    <!-- Onboarding -->
    <dimen name="onboarding_icon_size">48dp</dimen>
    <dimen name="onboarding_progress_height">4dp</dimen>

    <!-- Sensitivity slider -->
    <dimen name="slider_thumb_size">24dp</dimen>
    <dimen name="slider_track_height">6dp</dimen>

    <!-- Text sizes — all in sp for font scaling support -->
    <dimen name="text_display">28sp</dimen>
    <dimen name="text_headline">22sp</dimen>
    <dimen name="text_title">18sp</dimen>
    <dimen name="text_body">16sp</dimen>
    <dimen name="text_caption">14sp</dimen>
    <dimen name="text_label">12sp</dimen>

    <!-- Breathing circle -->
    <dimen name="breathe_circle_min">120dp</dimen>
    <dimen name="breathe_circle_max">240dp</dimen>

    <!-- Heatmap cell -->
    <dimen name="heatmap_cell_size">36dp</dimen>
    <dimen name="heatmap_cell_gap">4dp</dimen>
</resources>
